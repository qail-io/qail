  id UUID primary_key default gen_random_uuid()
  operator_id UUID references operators(id)
  created_at TIMESTAMPTZ not_null default now()
  idempotency_key TEXT
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table group_inquiries {
  notes TEXT
  status VARCHAR not_null default 'new'
  event_type VARCHAR not_null
  assigned_to UUID references users(id)
  travel_date_end DATE
  group_size INT not_null
  created_at TIMESTAMPTZ not_null default now()
  contact_email VARCHAR
  operator_id UUID references operators(id)
  travel_date_start DATE
  id UUID primary_key default gen_random_uuid()
  tenant_id UUID references tenants(id)
  contact_phone VARCHAR not_null
  updated_at TIMESTAMPTZ not_null default now()
  origin VARCHAR
  contact_name VARCHAR not_null
  destination VARCHAR
  enable_rls
  force_rls
}

table operator_boarding_points {
  is_primary BOOLEAN not_null default false
  updated_at TIMESTAMPTZ not_null default now()
  google_maps_url TEXT
  updated_by UUID not_null
  is_active BOOLEAN not_null default true
  created_by UUID not_null
  tenant_id UUID references tenants(id)
  address TEXT
  operator_id UUID not_null references operators(id) on_delete cascade
  boarding_type VARCHAR not_null default 'main'
  phone VARCHAR
  description TEXT
  latitude DOUBLE PRECISION
  deleted_at TIMESTAMPTZ
  name VARCHAR not_null
  waze_url TEXT
  id UUID primary_key default gen_random_uuid()
  longitude DOUBLE PRECISION
  harbor_id UUID not_null references harbors(id) on_delete cascade
  created_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

