policy articles_all_policy on articles for all
  using $$ (COALESCE(current_setting('app.is_super_admin'::text, true), 'false'::text) = 'true'::text OR ((operator_id IS NOT NULL AND operator_id = (current_setting('app.current_operator_id'::text, true))::uuid) OR (agent_id IS NOT NULL AND agent_id = (current_setting('app.current_agent_id'::text, true))::uuid))) $$

