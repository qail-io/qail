# QAIL Schema

extension "uuid-ossp" version "1.1"

enum article_status { draft, published, archived }
enum boarding_point_type { main, alternative, seasonal, vip }
enum charter_booking_status { pending, confirmed, cancelled, completed }
enum charter_category { fishing, charter, yacht }
enum charter_duration_type { hourly, half_day, full_day, sunset, multi_day }
enum charter_payment_status { unpaid, deposit_paid, fully_paid, refunded }
enum charter_price_type { per_boat, per_person, per_cabin, per_night }
enum charter_style { trolling, jigging, popping, bottom, reef }
enum charter_vessel_type { jukung, speedboat, sportfisher, phinisi, catamaran, yacht, traditional }
enum fishing_booking_status { pending, confirmed, cancelled, completed }
enum fishing_duration_type { hourly, half_day, full_day, sunset, multi_day }
enum fishing_payment_status { unpaid, deposit_paid, fully_paid, refunded }
enum fishing_price_type { per_boat, per_person, per_cabin, per_night }
enum fishing_style { trolling, jigging, popping, bottom, reef }
enum fishing_vessel_type { jukung, speedboat, sportfisher, phinisi, catamaran, yacht, traditional }
enum hold_status { Active, Expired, Confirmed, Released }
enum nationality { Indonesian, NonIndonesian }
enum operator_type { live, fast_sync, confirmation_needed, enquiry_only }
enum order_status { Draft, AwaitingPayment, Paid, Confirmed, Expired, Failed, Cancelled }
enum payment_session_status { Pending, AwaitingPayment, Authorized, Paid, Expired, Failed, Cancelled, Refunded }
enum refund_reason { UserRequested, SystemCancelled, Duplicate, Fraud, Reschedule, ServiceIssue, Other }
enum refund_status { Pending, Succeeded, Failed, Cancelled }
enum reservation_status { Confirmed, Cancelled, Refunded }
enum seo_comparison_type { operator_vs_operator, best_of }
enum user_role { admin, operator, customer, administrator, finance_admin, super_admin }
enum vessel_category { fishing, charter, yacht }
enum vessel_class { LUXURY, EXECUTIVE, BUSINESS, ECONOMY }
enum vessel_type { SPEEDBOAT, FAST_FERRY, FERRY, CRUISE, YACHT, FASTBOAT }

table tenants {
  is_active BOOLEAN not_null default true
  slug VARCHAR not_null unique
  id UUID primary_key default gen_random_uuid()
  contact_email VARCHAR
  updated_at TIMESTAMPTZ not_null default now()
  contact_phone VARCHAR
  created_at TIMESTAMPTZ not_null default now()
  name VARCHAR not_null
  api_key_hash VARCHAR
  can_resell BOOLEAN not_null default false
  can_operate BOOLEAN not_null default false
  logo_url TEXT
  verticals TEXT not_null default '{}'
  enable_rls
  force_rls
}

table service_groups {
  name VARCHAR not_null
  class VARCHAR not_null
  category VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  description TEXT
  updated_at TIMESTAMPTZ not_null default now()
  deleted_at TIMESTAMPTZ
  created_at TIMESTAMPTZ not_null default now()
  is_active BOOLEAN not_null default true
  sort_order INT not_null default 0
  enable_rls
  force_rls
}

table email_templates {
  is_system BOOLEAN not_null default false
  category VARCHAR not_null default 'email'
  tenant_id UUID references tenants(id)
  sample_data JSONB
  operator_id UUID references operators(id)
  is_active BOOLEAN not_null default true
  slug VARCHAR not_null unique
  created_by UUID references users(id)
  description TEXT
  id UUID primary_key default gen_random_uuid()
  name VARCHAR not_null
  created_at TIMESTAMPTZ not_null default now()
  tiptap_json JSONB
  updated_at TIMESTAMPTZ not_null default now()
  updated_by UUID references users(id)
  available_variables JSONB not_null default '[]'
  html_body TEXT not_null
  text_body TEXT
  subject_template TEXT not_null
  enable_rls
  force_rls
}

table payment_gateway_configs {
  is_active BOOLEAN not_null default false
  id UUID primary_key default gen_random_uuid()
  tenant_id UUID references tenants(id)
  display_name VARCHAR not_null
  merchant_id TEXT
  created_at TIMESTAMPTZ not_null default now()
  provider VARCHAR not_null unique
  updated_at TIMESTAMPTZ not_null default now()
  is_production BOOLEAN not_null default false
  operator_id UUID references operators(id)
  webhook_secret TEXT
  client_key TEXT
  server_key TEXT
  config JSONB not_null default '{}'
  enable_rls
  force_rls
}

table refresh_tokens {
  user_id UUID not_null references users(id) on_delete cascade
  created_at TIMESTAMPTZ not_null default now()
  token VARCHAR not_null unique
  id UUID primary_key default gen_random_uuid()
  expires_at TIMESTAMPTZ not_null
  revoked_at TIMESTAMPTZ
  enable_rls
  force_rls
}

table pricing_plans {
  created_at TIMESTAMPTZ not_null default now()
  name VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  currency VARCHAR not_null default 'IDR'
  virtual_segment_id UUID
  parent_route_id UUID
  segment_id UUID
  start_date DATE not_null
  end_date DATE not_null
  is_active BOOLEAN not_null default true
  priority INT not_null default 0
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table whatsapp_contact_group_members {
  contact_name VARCHAR
  added_at TIMESTAMPTZ not_null default now()
  group_id UUID primary_key references whatsapp_contact_groups(id) on_delete cascade
  contact_phone VARCHAR primary_key
  enable_rls
  force_rls
}

table postmark_events {
  tag VARCHAR
  processed_at TIMESTAMPTZ not_null default now()
  message_id VARCHAR
  id UUID primary_key default gen_random_uuid()
  click_location VARCHAR
  server_id INT
  bounce_type VARCHAR
  first_open BOOLEAN
  message_stream VARCHAR
  changed_at TIMESTAMPTZ
  event_type VARCHAR not_null
  bounce_description TEXT
  request_headers JSONB
  received_at TIMESTAMPTZ
  error_message TEXT
  bounced_at TIMESTAMPTZ
  complaint_id BIGINT
  platform VARCHAR
  email VARCHAR
  original_link TEXT
  recipient VARCHAR
  metadata JSONB default '{}'
  processing_status VARCHAR not_null default 'processed'
  raw_payload JSONB not_null
  sender VARCHAR
  source_ip TEXT
  origin VARCHAR
  read_seconds INT
  created_at TIMESTAMPTZ not_null default now()
  delivered_at TIMESTAMPTZ
  user_agent TEXT
  type_code INT
  suppression_reason VARCHAR
  suppress_sending BOOLEAN
  enable_rls
  force_rls
}

table vessel_images {
  created_at TIMESTAMPTZ not_null default now()
  created_by UUID not_null
  updated_by UUID not_null
  deleted_at TIMESTAMPTZ
  id UUID primary_key default gen_random_uuid()
  display_order INT not_null default 0
  updated_at TIMESTAMPTZ not_null default now()
  image_url TEXT not_null
  vessel_id UUID not_null references vessels(id) on_delete cascade
  caption TEXT
  enable_rls
  force_rls
}

table schedule_patterns {
  count INT
  interval INT not_null default 1
  id UUID primary_key default gen_random_uuid()
  by_weekday TEXT
  by_month TEXT
  frequency TEXT not_null
  created_at TIMESTAMPTZ not_null default now()
  start_date DATE not_null
  by_month_day TEXT
  end_date DATE
  until DATE
  enable_rls
  force_rls
}

table operator_facilities {
  name VARCHAR not_null
  updated_at TIMESTAMPTZ not_null default now()
  description TEXT
  id UUID primary_key default gen_random_uuid()
  icon VARCHAR
  tenant_id UUID references tenants(id)
  operator_id UUID not_null references operators(id) on_delete cascade
  updated_by UUID not_null
  created_by UUID not_null
  created_at TIMESTAMPTZ not_null default now()
  deleted_at TIMESTAMPTZ
  enable_rls
  force_rls
}

table seo_poros {
  destination TEXT not_null
  operator_count INT default 0
  dest_destination_id UUID references destinations(id)
  id UUID primary_key default gen_random_uuid()
  faqs JSONB default '[]'
  origin TEXT not_null
  min_price INT
  title TEXT not_null
  tips JSONB default '[]'
  created_by UUID
  updated_by UUID
  faqs_ja JSONB default '[]'
  translation_tokens_total INT default 0
  departures_per_day INT
  slug TEXT not_null
  updated_at TIMESTAMPTZ not_null default now()
  agent_id UUID references agents(id)
  distance TEXT
  origin_harbor_id UUID references harbors(id)
  tenant_id UUID references tenants(id)
  content_paragraphs JSONB default '[]'
  translation_status TEXT default 'pending'
  faqs_ko JSONB default '[]'
  avg_duration TEXT
  meta_description TEXT
  translation_hash TEXT
  is_published BOOLEAN not_null default false
  origin_destination_id UUID references destinations(id)
  dest_harbor_id UUID references harbors(id)
  translation_last_run TIMESTAMPTZ
  faqs_zh JSONB default '[]'
  faqs_id JSONB default '[]'
  operator_id UUID references operators(id)
  created_at TIMESTAMPTZ not_null default now()
  max_price INT
  enable_rls
  force_rls
}

table marketing_config {
  tiktok_pixel_id TEXT
  facebook_access_token TEXT
  tiktok_access_token TEXT
  created_at TIMESTAMPTZ not_null default now()
  tracking_enabled BOOLEAN not_null default true
  google_ads_conversion_id TEXT
  tenant_id UUID references tenants(id)
  id UUID primary_key default gen_random_uuid()
  google_ads_conversion_label TEXT
  agent_id UUID references agents(id)
  facebook_pixel_id TEXT
  operator_id UUID references operators(id)
  gtm_container_id TEXT
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table tenant_harbor_overrides {
  agent_id UUID references agents(id)
  seo_title_zh TEXT
  id UUID primary_key default gen_random_uuid()
  seo_description_ko TEXT
  og_image_url TEXT
  operator_id UUID references operators(id)
  map_image_url TEXT
  seo_description_zh TEXT
  is_hidden BOOLEAN not_null default false
  facilities TEXT
  seo_description TEXT
  harbor_id UUID not_null references harbors(id)
  seo_keywords TEXT
  seo_title_ko TEXT
  custom_slug TEXT
  seo_article TEXT
  seo_description_id TEXT
  position_override INT
  updated_at TIMESTAMPTZ not_null default now()
  photo_url TEXT
  created_at TIMESTAMPTZ not_null default now()
  custom_name TEXT
  operating_hours TEXT
  custom_description TEXT
  contact_email TEXT
  important_notes JSONB
  seo_title_ja TEXT
  seo_title TEXT
  seo_title_id TEXT
  seo_description_ja TEXT
  tenant_id UUID references tenants(id)
  contact_phone TEXT
  enable_rls
  force_rls
}

table search_location_stats {
  agent_id UUID references agents(id)
  created_at TIMESTAMPTZ not_null default now()
  selection_count BIGINT not_null default 0
  last_selected_at TIMESTAMPTZ
  tenant_id UUID references tenants(id)
  location_type VARCHAR not_null
  operator_id UUID references operators(id)
  location_slug VARCHAR
  id UUID primary_key default gen_random_uuid()
  location_name VARCHAR not_null
  updated_at TIMESTAMPTZ not_null default now()
  location_id UUID not_null
  enable_rls
  force_rls
}

table whatsapp_contact_groups {
  tenant_id UUID references tenants(id)
  operator_id UUID references operators(id)
  updated_at TIMESTAMPTZ not_null default now()
  name VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  created_at TIMESTAMPTZ not_null default now()
  description TEXT
  enable_rls
  force_rls
}

table ai_token_usage {
  tokens_out INT not_null default 0
  created_at TIMESTAMPTZ not_null default now()
  request_count INT not_null default 0
  operator_id UUID references operators(id)
  tokens_in INT not_null default 0
  tenant_id UUID references tenants(id)
  agent_id UUID references agents(id)
  id UUID primary_key default gen_random_uuid()
  usage_date DATE not_null default CURRENT_DATE
  enable_rls
  force_rls
}

table harbors {
  name_id VARCHAR
  created_by UUID not_null
  seo_article_id TEXT
  operating_hours TEXT
  seo_description TEXT not_null default ''
  port_fee_description_id TEXT
  seo_description_ko VARCHAR
  longitude DOUBLE PRECISION
  name_zh VARCHAR
  facilities JSONB default '[]'
  created_at TIMESTAMPTZ not_null default now()
  updated_by UUID not_null
  address TEXT
  name_ko VARCHAR
  seo_title_ko VARCHAR
  description_id TEXT
  contact_email TEXT
  seo_description_id VARCHAR
  seo_article_zh TEXT
  seo_article_ja TEXT
  seo_title_zh VARCHAR
  is_active BOOLEAN not_null default true
  country TEXT
  city TEXT
  tz_region VARCHAR
  google_maps_url TEXT
  description_ja TEXT
  seo_article_ko TEXT
  description_zh TEXT
  port_fee_description TEXT
  position INT not_null default 0
  seo_article TEXT
  seo_description_ja VARCHAR
  seo_title_id VARCHAR
  name TEXT not_null
  port_fee_amount DOUBLE PRECISION
  name_ja VARCHAR
  map_image_url TEXT
  description TEXT
  port_fee_description_zh TEXT
  photo_url TEXT
  description_ko TEXT
  updated_at TIMESTAMPTZ not_null default now()
  important_notes JSONB default '[]'
  latitude DOUBLE PRECISION
  seo_title TEXT not_null default ''
  slug TEXT not_null unique
  translation_hash VARCHAR
  seo_description_zh VARCHAR
  id UUID primary_key default gen_random_uuid()
  port_fee_description_ja TEXT
  contact_phone TEXT
  seo_keywords_zh VARCHAR
  timezone TEXT not_null default 'Asia/Makassar'
  seo_keywords TEXT not_null default ''
  seo_title_ja VARCHAR
  port_fee_description_ko TEXT
  seo_keywords_ja VARCHAR
  seo_keywords_ko VARCHAR
  seo_keywords_id VARCHAR
  enable_rls
  force_rls
}

table destination_seo_overrides {
  tenant_id UUID references tenants(id)
  meta_description TEXT
  created_at TIMESTAMPTZ default now()
  og_image_url TEXT
  operator_id UUID references operators(id) on_delete cascade
  meta_title VARCHAR
  updated_at TIMESTAMPTZ default now()
  agent_id UUID references agents(id) on_delete cascade
  id UUID primary_key default gen_random_uuid()
  destination_id UUID not_null references destinations(id) on_delete cascade
  enable_rls
  force_rls
}

table settlement_items {
  payout_amount BIGINT not_null
  created_at TIMESTAMPTZ not_null default now()
  order_total BIGINT not_null
  id UUID primary_key default gen_random_uuid()
  order_id UUID not_null references orders(id) on_delete cascade
  settlement_id UUID not_null references settlements(id) on_delete cascade
  commission_amount BIGINT not_null
  enable_rls
  force_rls
}

table agent_contracts {
  terminated_by UUID references users(id)
  approved_by UUID references users(id)
  is_active BOOLEAN default true
  valid_from DATE
  static_markup DOUBLE PRECISION
  commission_percent DOUBLE PRECISION
  termination_reason TEXT
  created_at TIMESTAMPTZ not_null default now()
  agent_id UUID not_null references agents(id) on_delete cascade
  updated_at TIMESTAMPTZ not_null default now()
  pricing_model VARCHAR not_null
  terminated_by_party VARCHAR
  id UUID primary_key default gen_random_uuid()
  terminated_at TIMESTAMPTZ
  operator_id UUID not_null references operators(id) on_delete cascade
  valid_until DATE
  enable_rls
  force_rls
}

table whatsapp_broadcast_recipients {
  read_at TIMESTAMPTZ
  sent_at TIMESTAMPTZ
  delivered_at TIMESTAMPTZ
  contact_phone VARCHAR primary_key
  error_message TEXT
  broadcast_id UUID primary_key references whatsapp_broadcasts(id) on_delete cascade
  status VARCHAR default 'pending'
  wa_message_id VARCHAR
  enable_rls
  force_rls
}

table user_payment_methods {
  is_active BOOLEAN default true
  card_expiry_year TEXT
  card_holder_name TEXT
  card_expiry_month TEXT
  card_last_four TEXT
  created_at TIMESTAMPTZ default now()
  user_id UUID not_null references users(id) on_delete cascade
  updated_at TIMESTAMPTZ default now()
  card_brand TEXT
  id UUID primary_key default gen_random_uuid()
  xendit_payment_token_id TEXT not_null unique
  is_default BOOLEAN default false
  enable_rls
  force_rls
}

table contract_route_rates {
  created_at TIMESTAMPTZ not_null default now()
  operator_id UUID not_null references operators(id)
  id UUID primary_key default gen_random_uuid()
  origin_harbor_id UUID not_null references harbors(id)
  destination_harbor_id UUID not_null references harbors(id)
  contract_id UUID not_null references agent_contracts(id) on_delete cascade
  tenant_id UUID references tenants(id)
  currency VARCHAR not_null default 'IDR'
  rate_amount DOUBLE PRECISION not_null
  notes TEXT
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table reservations {
  seats INT not_null
  id UUID primary_key default gen_random_uuid()
  hold_id UUID
  status TEXT not_null default 'Confirmed'
  updated_at TIMESTAMPTZ not_null default now()
  connection_id UUID not_null
  operator_id UUID references operators(id)
  nationality TEXT not_null
  tenant_id UUID references tenants(id)
  currency TEXT not_null default 'IDR'
  pax_breakdown JSONB not_null
  price_paid BIGINT not_null
  created_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table refunds {
  order_id UUID not_null references orders(id)
  initiated_by UUID references users(id)
  reason_notes TEXT
  updated_at TIMESTAMPTZ not_null default now()
  external_refund_id TEXT
  id UUID primary_key default gen_random_uuid()
  tenant_id UUID references tenants(id)
  manual_reference_id TEXT
  amount BIGINT not_null
  is_manual BOOLEAN not_null default false
  manual_transfer_note TEXT
  operator_id UUID references operators(id)
  payment_session_id UUID not_null references payment_sessions(id)
  status refund_status not_null default 'Pending'
  currency VARCHAR not_null default 'IDR'
  reason refund_reason not_null default 'UserRequested'
  created_at TIMESTAMPTZ not_null default now()
  completed_at TIMESTAMPTZ
  idempotency_key UUID not_null default gen_random_uuid()
  enable_rls
  force_rls
}

table agents {
  created_at TIMESTAMPTZ not_null default now()
  slug VARCHAR not_null unique
  id UUID primary_key default gen_random_uuid()
  contact_email VARCHAR
  contact_phone VARCHAR
  name VARCHAR not_null
  verticals TEXT not_null default '{}'
  is_active BOOLEAN default true
  api_key_hash VARCHAR
  created_by UUID references users(id)
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table user_email_verifications {
  created_at TIMESTAMPTZ not_null default now()
  token VARCHAR not_null unique
  id UUID primary_key default gen_random_uuid()
  expires_at TIMESTAMPTZ not_null
  consumed_at TIMESTAMPTZ
  user_id UUID not_null references users(id) on_delete cascade
  enable_rls
  force_rls
}

table whatsapp_flow_config {
  footer_text VARCHAR not_null default 'ExampleApp Booking'
  cta_text VARCHAR not_null default 'Book Fastboat'
  is_active BOOLEAN not_null default true
  header_text VARCHAR not_null default 'Book Your Fastboat Ticket'
  trigger_type VARCHAR not_null default 'booking'
  updated_at TIMESTAMPTZ not_null default now()
  flow_id VARCHAR not_null
  created_at TIMESTAMPTZ not_null default now()
  body_text TEXT not_null default 'Book your fastboat tickets to Nusa Penida, Gili, and Lembongan easily via WhatsApp!'
  flow_name VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  first_screen VARCHAR not_null
  enable_rls
  force_rls
}

table oauth_accounts {
  metadata JSONB default '{}'
  refresh_token TEXT
  token_expires_at TIMESTAMPTZ
  updated_at TIMESTAMPTZ not_null default now()
  provider_user_id VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  provider VARCHAR not_null
  created_at TIMESTAMPTZ not_null default now()
  user_id UUID not_null references users(id) on_delete cascade
  access_token TEXT
  enable_rls
  force_rls
}

table saved_passengers {
  created_at TIMESTAMPTZ not_null default now()
  updated_at TIMESTAMPTZ not_null default now()
  passenger_type VARCHAR not_null
  tenant_id UUID references tenants(id)
  title VARCHAR not_null
  id UUID primary_key default gen_random_uuid()
  full_name VARCHAR not_null
  operator_id UUID references operators(id)
  country VARCHAR not_null
  user_id UUID not_null references users(id) on_delete cascade
  enable_rls
  force_rls
}

table vessels {
  updated_by UUID not_null
  default_arrival_dock_id UUID
  seat_capacity INT not_null
  default_departure_dock_id UUID
  updated_at TIMESTAMPTZ not_null default now()
  id UUID primary_key default gen_random_uuid()
  name VARCHAR not_null
  created_by UUID not_null
  is_active BOOLEAN not_null default true
  operator_id UUID not_null references operators(id) on_delete cascade
  tenant_id UUID references tenants(id)
  facility TEXT not_null
  vessel_type vessel_type not_null
  slug VARCHAR not_null unique
  vessel_class vessel_class not_null
  created_at TIMESTAMPTZ not_null default now()
  deleted_at TIMESTAMPTZ
  active_since DATE not_null
  enable_rls
  force_rls
}

table vessel_facilities {
  created_at TIMESTAMPTZ not_null default now()
  created_by UUID not_null
  updated_by UUID not_null
  deleted_at TIMESTAMPTZ
  id UUID primary_key default gen_random_uuid()
  description TEXT
  updated_at TIMESTAMPTZ not_null default now()
  name TEXT not_null
  vessel_id UUID not_null references vessels(id) on_delete cascade
  icon TEXT
  enable_rls
  force_rls
}

table odyssey_connections {
  origin_harbor_id UUID not_null references harbors(id)
  created_at TIMESTAMPTZ not_null default now()
  destination_harbor_id UUID not_null references harbors(id)
  id UUID primary_key default gen_random_uuid()
  sales_start_date DATE
  operator_id UUID references operators(id)
  odyssey_id UUID not_null references odysseys(id) on_delete cascade
  tenant_id UUID references tenants(id)
  name VARCHAR not_null
  description TEXT
  leg_ids TEXT not_null default '{}'
  is_enabled BOOLEAN not_null default false
  updated_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table app_chat_messages {
  status TEXT not_null default 'sent'
  metadata JSONB
  created_at TIMESTAMPTZ not_null default now()
  tenant_id UUID references tenants(id)
  sender_type TEXT not_null
  message_type VARCHAR not_null default 'text'
  agent_id UUID references users(id) on_delete set_null
  id UUID primary_key default gen_random_uuid()
  content TEXT not_null
  session_id UUID not_null references app_chat_sessions(id) on_delete cascade
  enable_rls
  force_rls
}

table payment_events {
  payload JSONB not_null
  payment_session_id UUID not_null references payment_sessions(id) on_delete cascade
  id BIGINT primary_key
  provider_id TEXT
  tenant_id UUID references tenants(id)
  event_type TEXT not_null
  processed BOOLEAN not_null default false
  operator_id UUID references operators(id)
  created_at TIMESTAMPTZ not_null default now()
  enable_rls
  force_rls
}

table vessel_class_options {
  created_at TIMESTAMPTZ not_null default now()
  updated_at TIMESTAMPTZ not_null default now()
  position INT not_null default 0
  id UUID primary_key default uuid_generate_v4()
  label TEXT not_null
  value TEXT not_null unique
  is_active BOOLEAN not_null default true
  enable_rls
  force_rls
}

table schema_migrations {
  version VARCHAR primary_key
  applied_at TIMESTAMPTZ not_null default now()
}

table tenant_destination_overrides {
  seo_description_ko TEXT
  custom_display_name TEXT
  is_hidden BOOLEAN not_null default false
  transportation_info TEXT
  custom_description TEXT
  climate_info TEXT
  custom_name TEXT
  seo_description_zh TEXT
  og_image_url TEXT
  created_at TIMESTAMPTZ not_null default now()
  highlights JSONB
  best_time_to_visit TEXT
  travel_tips JSONB
  gallery_images JSONB
  updated_at TIMESTAMPTZ not_null default now()
  seo_title_zh TEXT
  id UUID primary_key default gen_random_uuid()
