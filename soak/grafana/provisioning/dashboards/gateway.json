{
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "title": "Request Rate (req/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(qail_http_requests_total[1m])",
                    "legendFormat": "{{method}} {{status}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
        {
            "title": "Response Latency (p50 / p95 / p99)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, rate(qail_http_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(qail_http_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p95",
                    "refId": "B"
                },
                {
                    "expr": "histogram_quantile(0.99, rate(qail_http_request_duration_seconds_bucket[5m]))",
                    "legendFormat": "p99",
                    "refId": "C"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 5
                    }
                }
            }
        },
        {
            "title": "Process Memory (RSS)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 8
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes{job=\"qail-gateway\"}",
                    "legendFormat": "RSS",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 15
                    }
                }
            }
        },
        {
            "title": "Connection Pool",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 8
            },
            "targets": [
                {
                    "expr": "qail_pool_active_connections",
                    "legendFormat": "Active",
                    "refId": "A"
                },
                {
                    "expr": "qail_pool_idle_connections",
                    "legendFormat": "Idle",
                    "refId": "B"
                },
                {
                    "expr": "qail_pool_max_connections",
                    "legendFormat": "Max",
                    "refId": "C"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        },
        {
            "title": "Cache Hit Ratio",
            "type": "gauge",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 8
            },
            "targets": [
                {
                    "expr": "rate(qail_cache_hits_total[5m]) / (rate(qail_cache_hits_total[5m]) + rate(qail_cache_misses_total[5m]))",
                    "legendFormat": "Hit Ratio",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.5
                            },
                            {
                                "color": "green",
                                "value": 0.8
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Error Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "targets": [
                {
                    "expr": "rate(qail_http_requests_total{status=~\"4..|5..\"}[1m])",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "drawStyle": "bars",
                        "fillOpacity": 50
                    }
                }
            }
        },
        {
            "title": "Rate Limiter Rejections",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 12,
                "y": 16
            },
            "targets": [
                {
                    "expr": "increase(qail_rate_limited_total[1h])",
                    "legendFormat": "Last Hour",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            }
        },
        {
            "title": "EXPLAIN Rejections",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 18,
                "y": 16
            },
            "targets": [
                {
                    "expr": "increase(qail_explain_rejections_total[1h])",
                    "legendFormat": "Last Hour",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            }
        },
        {
            "title": "Cache Entries & Size",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 24
            },
            "targets": [
                {
                    "expr": "qail_cache_entries",
                    "legendFormat": "Entries",
                    "refId": "A"
                },
                {
                    "expr": "qail_cache_weighted_bytes",
                    "legendFormat": "Weighted Bytes",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Weighted Bytes"
                        },
                        "properties": [
                            {
                                "id": "unit",
                                "value": "bytes"
                            }
                        ]
                    }
                ]
            }
        },
        {
            "title": "Query Performance",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 24
            },
            "targets": [
                {
                    "expr": "rate(qail_queries_total[1m])",
                    "legendFormat": "{{table}} {{action}} {{status}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10
                    }
                }
            }
        }
    ],
    "refresh": "5s",
